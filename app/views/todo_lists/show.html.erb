<h1 class="h3 mb-3"><%= @todo_list.name %></h1>

<ul class="list-group mb-3">
  <% @todo_list.todo_items.each do |item| %>
    <li class="list-group-item d-flex justify-content-between align-items-center">
      <%= link_to todo_list_todo_item_path(@todo_list, item), class: "text-decoration-none flex-grow-1", data: { turbo_method: :patch } do %>
        <span class="<%= item.completed ? 'text-decoration-line-through text-muted' : 'text-dark' %>" style="cursor: pointer;">
          <%= item.description %>
        </span>
      <% end %>
      <div class="btn-group btn-group-sm">
        <%= link_to 'Edit', edit_todo_list_todo_item_path(@todo_list, item), class: 'btn btn-outline-secondary' %>
        <%= link_to 'Delete', todo_list_todo_item_path(@todo_list, item), class: 'btn btn-outline-danger', data: { turbo_method: :delete, turbo_confirm: 'Are you sure you want to delete this item?' } %>
      </div>
    </li>
  <% end %>
</ul>

<div class="d-flex gap-2">
  <%= link_to 'Add Item', new_todo_list_todo_item_path(@todo_list), class: 'btn btn-primary btn-sm' %>
  <%= link_to 'Back', todo_lists_path, class: 'btn btn-outline-secondary btn-sm' %>
</div>

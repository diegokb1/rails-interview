<li id="<%= dom_id(todo_item) %>" class="list-group-item d-flex justify-content-between align-items-center">
  <%= link_to todo_list_todo_item_path(todo_item.todo_list, todo_item), class: "text-decoration-none flex-grow-1", data: { turbo_method: :patch } do %>
    <span class="<%= todo_item.completed ? 'text-decoration-line-through text-muted' : 'text-dark' %>" style="cursor: pointer;">
      <%= todo_item.description %>
    </span>
  <% end %>
  <div class="btn-group btn-group-sm">
    <%= link_to 'Edit', edit_todo_list_todo_item_path(todo_item.todo_list, todo_item), class: "btn btn-outline-secondary #{'disabled' if todo_item.completed}", aria: { disabled: todo_item.completed } %>
    <%= link_to 'Delete', todo_list_todo_item_path(todo_item.todo_list, todo_item), class: "btn btn-outline-danger #{'disabled' if todo_item.completed}", aria: { disabled: todo_item.completed }, data: { turbo_method: :delete, turbo_confirm: 'Are you sure you want to delete this item?' } %>
  </div>
</li>

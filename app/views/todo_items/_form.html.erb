<% if todo_item.errors.any? %>
  <div class="alert alert-danger">
    <ul class="mb-0">
      <% todo_item.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<%= form_with model: [todo_list, todo_item], id: "todo-item-form", class: "row g-3" do |f| %>
  <div class="col-md-6">
    <%= f.label :description, class: "form-label" %>
    <%= f.text_field :description, required: true, class: "form-control" %>
  </div>
<% end %>

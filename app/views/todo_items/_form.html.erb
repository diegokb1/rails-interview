<% if todo_item.errors.any? %>
  <ul>
    <% todo_item.errors.full_messages.each do |message| %>
      <li><%= message %></li>
    <% end %>
  </ul>
<% end %>

<%= form_with model: [todo_list, todo_item] do |f| %>
  <%= f.label :description %>
  <%= f.text_field :description, required: true %>

  <%= f.submit %>
<% end %>
